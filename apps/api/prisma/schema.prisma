generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum DispositionAction {
  ARCHIVE
  DESTROY
}

enum Classification {
  DEPARTMENTAL
  INSTITUTIONAL
  INTERNAL
  CONFIDENTIAL
  FOR_APPROVAL
}

enum PermissionLevel {
  READ
  WRITE
}

enum RecordStatus {
  DRAFT
  FINAL
  IN_TRANSIT
}

enum DistributionStatus {
  PENDING
  RECEIVED
}

enum TransitStatus {
  PENDING
  CURRENT
  APPROVED
  REJECTED
}

// apps/api/prisma/schema.prisma
model User {
  id                       String                 @id // Supabase Auth User ID
  email                    String                 @unique
  firstName                String
  middleName               String?
  lastName                 String
  imageUrl                 String? // URL for the user's profile picture
  institution              Institution?           @relation(fields: [institutionId], references: [id])
  institutionId            String?
  campus                   Campus?                @relation(fields: [campusId], references: [id])
  campusId                 String?
  department               Department?            @relation(fields: [departmentId], references: [id])
  departmentId             String?
  documents                Document[]             @relation("uploadedBy")
  documentVersions         DocumentVersion[]      @relation("versionUploadedBy")
  roles                    Role[] // Implicit M:N
  logs                     Log[]
  Remark                   Remark[]
  reviewRequested          DocumentWorkflow[]     @relation("DocumentReviewRequester")
  checkedOutDocs           DocumentWorkflow[]     @relation("CheckedOutDocs")
  notifications            Notification[]
  documentAccesses         DocumentAccess[]
  dispositionRequestedDocs DocumentLifecycle[]    @relation("dispositionRequester")
  sentDistributions        DocumentDistribution[] @relation("DistributionSender")
  receivedDistributions    DocumentDistribution[] @relation("DistributionRecipient")
  approvedTransitRoutes    DocumentTransitRoute[] @relation("RouteApprovedBy")
}

model Notification {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  title      String
  message    String
  isRead     Boolean  @default(false)
  documentId String? // Optional reference to a document for navigation
  createdAt  DateTime @default(now())

  @@index([userId])
}

model Role {
  id                   String           @id @default(cuid())
  name                 String
  level                Int              @default(4) // 0: Executive, 1: Leader, 2: Co-Leader, 3: Elder, 4: Member
  canManageUsers       Boolean          @default(false)
  canManageRoles       Boolean          @default(false)
  canManageDocuments   Boolean          @default(false)
  canManageInstitution Boolean          @default(false)
  users                User[] // Implicit M:N
  documentAccesses     DocumentAccess[]
  department           Department       @relation(fields: [departmentId], references: [id])
  departmentId         String
}

model Institution {
  id               String           @id @default(cuid())
  name             String
  acronym          String
  users            User[]
  campuses         Campus[]
  documents        Document[]
  documentTypes    DocumentType[]
  logs             Log[]
  documentAccesses DocumentAccess[]
}

model Campus {
  id               String           @id @default(cuid())
  name             String
  institution      Institution      @relation(fields: [institutionId], references: [id])
  institutionId    String
  departments      Department[]
  users            User[]
  documents        Document[]
  documentAccesses DocumentAccess[]
  logs             Log[]
}

model Department {
  id               String                 @id @default(cuid())
  name             String
  icon             String                 @default("default-icon.png")
  campus           Campus                 @relation(fields: [campusId], references: [id])
  campusId         String
  users            User[]
  roles            Role[]
  documents        Document[]
  documentAccesses DocumentAccess[]
  transitRoutes    DocumentTransitRoute[]
  logs             Log[]
}

model Log {
  id            String      @id @default(cuid())
  user          User        @relation(fields: [userId], references: [id])
  userId        String
  action        String
  institution   Institution @relation(fields: [institutionId], references: [id])
  institutionId String
  campus        Campus?     @relation(fields: [campusId], references: [id])
  campusId      String?
  department    Department? @relation(fields: [departmentId], references: [id])
  departmentId  String?
  userRole      String
  createdAt     DateTime    @default(now())
}

model DocumentType {
  id                      String      @id @default(cuid())
  name                    String
  color                   String
  institution             Institution @relation(fields: [institutionId], references: [id])
  institutionId           String
  documents               Document[]
  activeRetentionDuration Int         @default(0) // In Years
  activeRetentionMonths   Int         @default(0) // In Months
  activeRetentionDays     Int         @default(0) // In Days

  inactiveRetentionDuration Int @default(0) // In Years
  inactiveRetentionMonths   Int @default(0) // In Months
  inactiveRetentionDays     Int @default(0) // In Days

  dispositionAction DispositionAction @default(ARCHIVE)
}

model Document {
  id               String                 @id @default(cuid())
  fileName         String
  controlNumber    String?
  title            String
  content          String
  documentType     DocumentType?          @relation(fields: [documentTypeId], references: [id])
  documentTypeId   String?
  uploadedBy       User                   @relation("uploadedBy", fields: [uploadedById], references: [id])
  uploadedById     String
  originalSenderId String?
  classification   Classification         @default(INTERNAL)
  institution      Institution            @relation(fields: [institutionId], references: [id])
  institutionId    String
  // Optional relations to quickly filter by campus or department
  campus           Campus?                @relation(fields: [campusId], references: [id])
  campusId         String?
  department       Department?            @relation(fields: [departmentId], references: [id])
  departmentId     String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  versions         DocumentVersion[]
  remarks          Remark[]
  documentAccesses DocumentAccess[]
  distributions    DocumentDistribution[]
  transitRoutes    DocumentTransitRoute[]

  lifecycle DocumentLifecycle?
  workflow  DocumentWorkflow?

  metadata Json?

  @@index([institutionId])
  @@index([uploadedById])
  @@index([documentTypeId])
  @@index([classification])
  @@index([originalSenderId])
  @@index([campusId])
  @@index([departmentId])
  @@index([campusId, departmentId])
  @@index([institutionId, classification])
}

model DocumentLifecycle {
  id         String   @id @default(cuid())
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId String   @unique

  activeRetentionSnapshot       Int?
  activeRetentionMonthsSnapshot Int?
  activeRetentionDaysSnapshot   Int?

  inactiveRetentionSnapshot       Int?
  inactiveRetentionMonthsSnapshot Int?
  inactiveRetentionDaysSnapshot   Int?

  dispositionActionSnapshot DispositionAction?
  dispositionStatus         String? // 'ARCHIVED', 'DESTROYED', 'PENDING_DISPOSITION'
  dispositionDate           DateTime? // The exact date the disposition was executed
  archiveManifestUrl        String?
  archiveHash               String?

  isUnderLegalHold Boolean @default(false)
  legalHoldReason  String?

  dispositionRequesterId String?
  dispositionRequester   User?   @relation("dispositionRequester", fields: [dispositionRequesterId], references: [id])
}

model DocumentWorkflow {
  id         String   @id @default(cuid())
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId String   @unique

  recordStatus RecordStatus @default(DRAFT)
  status       String? // eg. approved, returned, disapproved

  isCheckedOut   Boolean @default(false)
  checkedOutBy   User?   @relation("CheckedOutDocs", fields: [checkedOutById], references: [id])
  checkedOutById String?

  reviewRequester   User?   @relation("DocumentReviewRequester", fields: [reviewRequesterId], references: [id])
  reviewRequesterId String?
}

model DocumentVersion {
  id            String   @id @default(cuid())
  versionNumber Int
  s3Key         String   @unique
  s3Bucket      String
  fileType      String?
  fileSize      Int?
  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId    String
  uploadedBy    User     @relation("versionUploadedBy", fields: [uploadedById], references: [id])
  uploadedById  String
  createdAt     DateTime @default(now())

  @@index([documentId])
  @@index([uploadedById])
}

model Remark {
  id         String   @id @default(cuid())
  message    String
  document   Document @relation(fields: [documentId], references: [id])
  documentId String
  author     User     @relation(fields: [authorId], references: [id])
  authorId   String
  createdAt  DateTime @default(now())
}

model DocumentAccess {
  id            String          @id @default(cuid())
  document      Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId    String
  // Can be granted to a specific user, role, department, campus, or institution
  userId        String?
  user          User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId        String?
  role          Role?           @relation(fields: [roleId], references: [id], onDelete: Cascade)
  departmentId  String?
  department    Department?     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  campusId      String?
  campus        Campus?         @relation(fields: [campusId], references: [id], onDelete: Cascade)
  institutionId String?
  institution   Institution?    @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  permission    PermissionLevel @default(READ)

  @@index([documentId])
  @@index([userId])
  @@index([roleId])
  @@index([departmentId])
  @@index([campusId])
  @@index([institutionId])
}

model DocumentDistribution {
  id          String             @id @default(cuid())
  document    Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId  String
  sender      User               @relation("DistributionSender", fields: [senderId], references: [id])
  senderId    String
  recipient   User               @relation("DistributionRecipient", fields: [recipientId], references: [id])
  recipientId String
  status      DistributionStatus @default(PENDING) // Enum: PENDING, RECEIVED
  createdAt   DateTime           @default(now())
  receivedAt  DateTime?

  @@index([documentId])
  @@index([senderId])
  @@index([recipientId])
}

model DocumentTransitRoute {
  id            String        @id @default(cuid())
  document      Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId    String
  department    Department    @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  departmentId  String
  sequenceOrder Int
  status        TransitStatus @default(PENDING)
  decision      String? // e.g. "Noted", "For Endorsement", "Approved"
  approvedBy    User?         @relation("RouteApprovedBy", fields: [approvedById], references: [id])
  approvedById  String?
  approvedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([documentId])
  @@index([departmentId])
  @@index([approvedById])
}
