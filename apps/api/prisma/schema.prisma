// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum DispositionAction {
  ARCHIVE
  DESTROY
}

enum Classification {
  INSTITUTIONAL
  CAMPUS
  INTERNAL
  CONFIDENTIAL
}

enum PermissionLevel {
  READ
  WRITE
}

// apps/api/prisma/schema.prisma

model User {
  id         String  @id // Supabase Auth User ID
  email      String  @unique
  firstName  String
  middleName String?
  lastName   String
  imageUrl   String? // URL for the user's profile picture

  institution   Institution? @relation(fields: [institutionId], references: [id])
  institutionId String?

  campus   Campus? @relation(fields: [campusId], references: [id])
  campusId String?

  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?

  isSuperAdmin Boolean @default(false)

  documents        Document[]       @relation("uploadedBy")
  roles            Role[] // Implicit M:N
  logs             Log[]
  Remark           Remark[]
  reviewRequested  Document[]       @relation("DocumentReviewRequester")
  notifications    Notification[]
  documentAccesses DocumentAccess[]
}

model Notification {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  title      String
  message    String
  isRead     Boolean  @default(false)
  documentId String? // Optional reference to a document for navigation
  createdAt  DateTime @default(now())

  @@index([userId])
}

model Role {
  id                 String           @id @default(cuid())
  name               String
  level              Int              @default(4) // 1: Leader, 2: Co-Leader, 3: Elder, 4: Member
  canManageUsers     Boolean          @default(false)
  canManageRoles     Boolean          @default(false)
  canManageDocuments Boolean          @default(false)
  users              User[] // Implicit M:N
  documentAccesses   DocumentAccess[]

  department   Department @relation(fields: [departmentId], references: [id])
  departmentId String
}

model Institution {
  id               String           @id @default(cuid())
  name             String
  acronym          String
  users            User[]
  campuses         Campus[]
  documents        Document[]
  documentTypes    DocumentType[]
  logs             Log[]
  documentAccesses DocumentAccess[]
}

model Campus {
  id               String           @id @default(cuid())
  name             String
  institution      Institution      @relation(fields: [institutionId], references: [id])
  institutionId    String
  departments      Department[]
  users            User[]
  documents        Document[]
  documentAccesses DocumentAccess[]
}

model Department {
  id               String           @id @default(cuid())
  name             String
  icon             String           @default("default-icon.png")
  campus           Campus           @relation(fields: [campusId], references: [id])
  campusId         String
  users            User[]
  roles            Role[]
  documents        Document[]
  documentAccesses DocumentAccess[]
}

model Log {
  id            String      @id @default(cuid())
  user          User        @relation(fields: [userId], references: [id])
  userId        String
  action        String
  institution   Institution @relation(fields: [institutionId], references: [id])
  institutionId String
  userRole      String
  createdAt     DateTime    @default(now())
}

model DocumentType {
  id                        String            @id @default(cuid())
  name                      String
  color                     String
  institution               Institution       @relation(fields: [institutionId], references: [id])
  institutionId             String
  documents                 Document[]
  activeRetentionDuration   Int               @default(0) // In Years
  inactiveRetentionDuration Int               @default(0) // In Years
  dispositionAction         DispositionAction @default(ARCHIVE)
}

model Document {
  id            String  @id @default(cuid())
  fileName      String
  controlNumber String?
  title         String
  content       String
  s3Key         String  @unique
  s3Bucket      String

  documentType   DocumentType? @relation(fields: [documentTypeId], references: [id])
  documentTypeId String?

  uploadedBy   User   @relation("uploadedBy", fields: [uploadedById], references: [id])
  uploadedById String

  originalSenderId String?

  classification Classification @default(INTERNAL)

  institution   Institution @relation(fields: [institutionId], references: [id])
  institutionId String

  // Optional relations to quickly filter by campus or department
  campus   Campus? @relation(fields: [campusId], references: [id])
  campusId String?

  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fileType String?
  fileSize Int?

  tags Tag[] // Implicit M:N

  reviewRequester   User?   @relation("DocumentReviewRequester", fields: [reviewRequesterId], references: [id])
  reviewRequesterId String?

  status  String? // eg. approved, returned, disapproved
  remarks Remark[]

  activeRetentionSnapshot   Int?
  inactiveRetentionSnapshot Int?
  dispositionActionSnapshot DispositionAction?
  dispositionStatus         String? // 'ARCHIVED', 'DESTROYED'
  documentAccesses          DocumentAccess[]

  @@index([institutionId])
  @@index([uploadedById])
  @@index([documentTypeId])
  @@index([classification])
  @@index([originalSenderId])
  @@index([campusId])
  @@index([departmentId])
}

model Tag {
  id        String     @id @default(cuid())
  name      String     @unique
  documents Document[] // Implicit M:N
  isGlobal  Boolean    @default(false)
  isLocked  Boolean    @default(false)
}

model Remark {
  id         String   @id @default(cuid())
  message    String
  document   Document @relation(fields: [documentId], references: [id])
  documentId String
  author     User     @relation(fields: [authorId], references: [id])
  authorId   String
  createdAt  DateTime @default(now())
}

model DocumentAccess {
  id         String   @id @default(cuid())
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId String

  // Can be granted to a specific user, role, department, campus, or institution
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  roleId String?
  role   Role?   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  campusId String?
  campus   Campus? @relation(fields: [campusId], references: [id], onDelete: Cascade)

  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  permission PermissionLevel @default(READ)

  @@index([documentId])
  @@index([userId])
  @@index([roleId])
  @@index([departmentId])
  @@index([campusId])
  @@index([institutionId])
}
